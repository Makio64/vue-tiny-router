{
  "name": "vue-tiny-router",
  "version": "1.8.0",
  "type": "module",
  "description": "A lightweight Vue 3 router (~1.33 kB Brotli) with route params, guards, lazy loading, and redirects",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./index.d.ts"
    }
  },
  "types": "index.d.ts",
  "files": [
    "src",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint . --fix",
    "test": "vitest run",
    "build": "vite build",
    "size:check": "size-limit",
    "prepublishOnly": "pnpm run build",
    "example:dev": "cd example && pnpm run dev",
    "example:build": "cd example && pnpm run build",
    "example:preview": "cd example && pnpm run preview",
    "docs:dev": "cd docs && pnpm run docs:dev",
    "docs:build": "cd docs && pnpm run docs:build",
    "docs:preview": "cd docs && pnpm run docs:preview",
    "dev": "pnpm run example:dev",
    "start": "pnpm run example:dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Makio64/vue-tiny-router.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "router",
    "routing",
    "lightweight",
    "tiny",
    "minimal",
    "component",
    "spa",
    "single-page-app",
    "navigation",
    "history-api",
    "bundle-size"
  ],
  "author": "Makio64 | David Ronai <davronai@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Makio64/vue-tiny-router/issues"
  },
  "homepage": "https://github.com/Makio64/vue-tiny-router#readme",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "gzip-size": "^7.0.0",
    "jsdom": "^29.0.2",
    "size-limit": "^12.1.0",
    "terser": "^5.46.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "size-limit": [
    {
      "name": "vue-tiny-router (ES Module)",
      "path": "dist/index.js",
      "limit": "1.5 KB",
      "brotli": true
    }
  ]
}
